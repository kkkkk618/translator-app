<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>智能翻译系统</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 1400px; margin: 0 auto; }
        .header { text-align: center; color: white; margin-bottom: 30px; }
        .header h1 { font-size: 2.5rem; margin-bottom: 10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2); }
        .header p { font-size: 1.1rem; opacity: 0.9; }
        .tabs { display: flex; justify-content: center; gap: 10px; margin-bottom: 30px; flex-wrap: wrap; }
        .tab-btn {
            padding: 12px 30px;
            font-size: 1rem;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: rgba(255,255,255,0.2);
            color: white;
            font-weight: 500;
        }
        .tab-btn:hover { background: rgba(255,255,255,0.3); transform: translateY(-2px); }
        .tab-btn.active { background: white; color: #667eea; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .tab-content {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            display: none;
        }
        .tab-content.active { display: block; }
        .translate-section { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .input-group, .output-group { display: flex; flex-direction: column; }
        .lang-select { display: flex; align-items: center; gap: 10px; margin-bottom: 15px; }
        .lang-select select {
            padding: 10px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 1rem;
            cursor: pointer;
            background: white;
            color: #333;
        }
        .lang-select select:focus { outline: none; border-color: #667eea; }
        .swap-btn {
            width: 40px; height: 40px;
            border-radius: 50%;
            border: 2px solid #e0e0e0;
            background: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            transition: all 0.3s ease;
        }
        .swap-btn:hover { border-color: #667eea; background: #f0f0ff; transform: rotate(180deg); }
        .text-area {
            flex: 1; min-height: 300px;
            padding: 20px;
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            font-size: 1.1rem;
            resize: none;
            font-family: inherit;
            transition: all 0.3s ease;
        }
        .text-area:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.1); }
        .text-area.output { background: #f8f9fa; border-color: #dee2e6; }
        .translate-btn {
            margin-top: 20px;
            padding: 15px 40px;
            font-size: 1.1rem;
            font-weight: 600;
            border: none;
            border-radius: 50px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(102,126,234,0.4);
        }
        .translate-btn:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(102,126,234,0.5); }
        .translate-btn:disabled { opacity: 0.6; cursor: not-allowed; }
        .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 30px; }
        .feature-card { background: #f8f9fa; padding: 20px; border-radius: 15px; text-align: center; }
        .feature-card i { font-size: 2.5rem; margin-bottom: 15px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .feature-card h3 { margin-bottom: 10px; color: #333; }
        .feature-card p { color: #666; font-size: 0.9rem; }
        .memory-section { max-height: 600px; overflow-y: auto; }
        .search-bar {
            width: 100%; padding: 12px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 30px;
            font-size: 1rem;
            margin-bottom: 20px;
        }
        .search-bar:focus { outline: none; border-color: #667eea; }
        .memory-list { display: flex; flex-direction: column; gap: 15px; }
        .memory-item {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 15px;
            border-left: 5px solid #667eea;
            transition: all 0.3s ease;
        }
        .memory-item:hover { transform: translateX(5px); box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .memory-text { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .memory-source { flex: 1; padding-right: 20px; }
        .memory-target { flex: 1; padding-left: 20px; border-left: 2px solid #e0e0e0; }
        .memory-source span, .memory-target span { font-size: 0.85rem; color: #888; display: block; margin-bottom: 5px; }
        .memory-time { font-size: 0.8rem; color: #aaa; text-align: right; }
        .memory-actions { display: flex; gap: 10px; margin-top: 10px; justify-content: flex-end; }
        .action-btn { padding: 6px 15px; border: none; border-radius: 20px; font-size: 0.85rem; cursor: pointer; transition: all 0.3s ease; }
        .action-btn.copy { background: #e3f2fd; color: #1976d2; }
        .action-btn.copy:hover { background: #bbdefb; }
        .action-btn.delete { background: #ffebee; color: #d32f2f; }
        .action-btn.delete:hover { background: #ffcdd2; }
        .action-btn.restore { background: #e8f5e9; color: #388e3c; }
        .action-btn.restore:hover { background: #c8e6c9; }
        .empty-state { text-align: center; padding: 60px 20px; color: #999; }
        .empty-state i { font-size: 4rem; margin-bottom: 20px; opacity: 0.5; }
        .corpus-section { max-height: 600px; overflow-y: auto; }
        .corpus-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
        .corpus-card {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .corpus-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
        .corpus-card h3 { margin-bottom: 10px; color: #667eea; font-size: 1rem; }
        .corpus-card p { color: #666; font-size: 0.9rem; line-height: 1.6; }
        .corpus-category { display: inline-block; padding: 4px 12px; background: #e3f2fd; color: #1976d2; border-radius: 20px; font-size: 0.8rem; margin-top: 10px; }
        .subtitle-section { display: flex; flex-direction: column; align-items: center; }
        .subtitle-display {
            width: 100%; max-width: 800px; min-height: 200px;
            background: #2d2d2d; color: white;
            padding: 40px 30px; border-radius: 20px;
            text-align: center; margin-bottom: 30px;
            font-size: 1.5rem; line-height: 1.8;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            display: flex; flex-direction: column; justify-content: center;
        }
        .subtitle-original { color: #ffd54f; margin-bottom: 15px; }
        .subtitle-translated { color: #4dd0e1; font-size: 1.3rem; }
        .subtitle-controls { display: flex; gap: 20px; align-items: center; }
        .mic-btn {
            width: 80px; height: 80px;
            border-radius: 50%; border: none;
            background: linear-gradient(135deg, #ef5350 0%, #e53935 100%);
            color: white; font-size: 2rem;
            cursor: pointer; transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(239,83,80,0.4);
            display: flex; align-items: center; justify-content: center;
        }
        .mic-btn:hover { transform: scale(1.05); box-shadow: 0 6px 25px rgba(239,83,80,0.5); }
        .mic-btn.active {
            animation: pulse 1.5s infinite;
            background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
            box-shadow: 0 4px 20px rgba(102,187,106,0.4);
        }
        @keyframes pulse {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(102,187,106,0.7); }
            70% { transform: scale(1.1); box-shadow: 0 0 0 20px rgba(102,187,106,0); }
            100% { transform: scale(1); }
        }
        .subtitle-status { font-size: 1rem; color: #666; }
        .stats-bar { display: flex; justify-content: space-around; background: #f8f9fa; padding: 20px; border-radius: 15px; margin-top: 30px; }
        .stat-item { text-align: center; }
        .stat-item .number { font-size: 2rem; font-weight: bold; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .stat-item .label { font-size: 0.9rem; color: #666; margin-top: 5px; }
        .loading-spinner {
            display: inline-block; width: 20px; height: 20px;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%; border-top-color: white;
            animation: spin 1s ease-in-out infinite;
            margin-right: 10px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .api-info { background: #e3f2fd; padding: 15px; border-radius: 10px; margin-top: 20px; font-size: 0.9rem; color: #1565c0; border-left: 4px solid #1976d2; }
        @media (max-width: 768px) {
            .translate-section { grid-template-columns: 1fr; }
            .header h1 { font-size: 1.8rem; }
            .tab-btn { padding: 10px 20px; font-size: 0.9rem; }
            .subtitle-display { font-size: 1.2rem; padding: 30px 20px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🌐 智能翻译系统</h1>
            <p>支持文本翻译、翻译记忆库、语料库查询、实时字幕</p>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('translate')">文本翻译</button>
            <button class="tab-btn" onclick="switchTab('memory')">翻译记忆库</button>
            <button class="tab-btn" onclick="switchTab('corpus')">语料库</button>
            <button class="tab-btn" onclick="switchTab('subtitle')">实时字幕</button>
        </div>

        <div id="translate" class="tab-content active">
            <div class="translate-section">
                <div class="input-group">
                    <div class="lang-select">
                        <select id="sourceLang">
                            <option value="en">英语</option>
                            <option value="zh">中文</option>
                            <option value="ja">日语</option>
                            <option value="ko">韩语</option>
                            <option value="fr">法语</option>
                            <option value="de">德语</option>
                            <option value="es">西班牙语</option>
                            <option value="ru">俄语</option>
                        </select>
                        <button class="swap-btn" onclick="swapLanguages()">↔</button>
                    </div>
                    <textarea id="inputText" class="text-area" placeholder="请输入要翻译的文本..."></textarea>
                </div>
                <div class="output-group">
                    <div class="lang-select">
                        <select id="targetLang">
                            <option value="zh" selected>中文</option>
                            <option value="en">英语</option>
                            <option value="ja">日语</option>
                            <option value="ko">韩语</option>
                            <option value="fr">法语</option>
                            <option value="de">德语</option>
                            <option value="es">西班牙语</option>
                            <option value="ru">俄语</option>
                        </select>
                    </div>
                    <textarea id="outputText" class="text-area output" readonly placeholder="翻译结果将显示在这里..."></textarea>
                </div>
            </div>
            <button class="translate-btn" onclick="translateText()" id="translateBtn">
                <span id="btnText">开始翻译</span>
            </button>

            <div class="features">
                <div class="feature-card">
                    <i>🎯</i>
                    <h3>精准翻译</h3>
                    <p>基于先进的机器翻译API，提供高质量的多语言翻译服务</p>
                </div>
                <div class="feature-card">
                    <i>💾</i>
                    <h3>翻译记忆</h3>
                    <p>自动保存翻译历史，重复内容快速匹配，提高翻译效率</p>
                </div>
                <div class="feature-card">
                    <i>📚</i>
                    <h3>语料库</h3>
                    <p>内置丰富的双语语料，为翻译提供参考依据</p>
                </div>
                <div class="feature-card">
                    <i>🎤</i>
                    <h3>实时字幕</h3>
                    <p>语音识别实时翻译，支持会议、演讲等场景</p>
                </div>
            </div>

            <div class="api-info">
                <strong>API说明：</strong>本系统使用Google Translate API进行翻译，支持8种主流语言互译。翻译结果仅供参考，请根据实际需求进行调整。
            </div>
        </div>

        <div id="memory" class="tab-content">
            <h2>📋 翻译记忆库</h2>
            <p style="color: #666; margin-bottom: 20px;">自动保存您的翻译历史，支持搜索和快速恢复</p>
            
            <input type="text" class="search-bar" id="memorySearch" placeholder="搜索翻译记录..." oninput="searchMemory()">
            
            <div class="memory-section">
                <div id="memoryList" class="memory-list">
                    <div class="empty-state">
                        <i>📭</i>
                        <p>暂无翻译记录</p>
                        <p style="font-size: 0.9rem; margin-top: 10px;">在"文本翻译"页面进行翻译后，记录会自动保存到这里</p>
                    </div>
                </div>
            </div>

            <div class="stats-bar">
                <div class="stat-item">
                    <div class="number" id="totalTranslations">0</div>
                    <div class="label">总翻译次数</div>
                </div>
                <div class="stat-item">
                    <div class="number" id="memoryMatches">0</div>
                    <div class="label">记忆匹配次数</div>
                </div>
                <div class="stat-item">
                    <div class="number" id="savedTime">0</div>
                    <div class="label">节省时间(秒)</div>
                </div>
            </div>
        </div>

        <div id="corpus" class="tab-content">
            <h2>📚 语料库</h2>
            <p style="color: #666; margin-bottom: 20px;">内置丰富的双语语料，涵盖多个领域</p>
            
            <input type="text" class="search-bar" id="corpusSearch" placeholder="搜索语料..." oninput="searchCorpus()">
            
            <div class="corpus-section">
                <div id="corpusGrid" class="corpus-grid">
                </div>
            </div>

            <div class="api-info" style="margin-top: 30px;">
                <strong>语料库说明：</strong>语料库包含商务、科技、旅游、文化等多个领域的双语对照文本，可作为翻译参考。点击卡片可查看详细内容。
            </div>
        </div>

        <div id="subtitle" class="tab-content">
            <h2>🎤 实时字幕</h2>
            <p style="color: #666; margin-bottom: 20px;">使用语音识别功能，实时生成双语字幕</p>
            
            <div class="subtitle-section">
                <div class="subtitle-display">
                    <div class="subtitle-original" id="subtitleOriginal">点击麦克风开始说话...</div>
                    <div class="subtitle-translated" id="subtitleTranslated"></div>
                </div>
                
                <div class="subtitle-controls">
                    <button class="mic-btn" id="micBtn" onclick="toggleSubtitle()">🎤</button>
                    <div class="subtitle-status" id="subtitleStatus">准备就绪</div>
                </div>

                <div style="margin-top: 30px; display: flex; gap: 20px;">
                    <div class="lang-select">
                        <select id="subtitleSourceLang">
                            <option value="en">英语</option>
                            <option value="zh" selected>中文</option>
                        </select>
                        <span style="font-weight: bold;">→</span>
                        <select id="subtitleTargetLang">
                            <option value="zh" selected>中文</option>
                            <option value="en">英语</option>
                        </select>
                    </div>
                </div>

                <div class="api-info" style="margin-top: 30px; max-width: 600px;">
                    <strong>注意：</strong>实时字幕功能需要浏览器支持Web Speech API。目前Chrome、Edge等现代浏览器均支持此功能。请确保麦克风权限已开启。
                </div>
            </div>
        </div>
    </div>

    <script>
        const DB_NAME = 'TranslatorDB';
        const DB_VERSION = 1;
        const STORE_NAME = 'translations';

        const corpusData = [
            { category: '商务', source: 'We are pleased to announce the new partnership.', target: '我们很高兴宣布新的合作伙伴关系。' },
            { category: '商务', source: 'Please find attached the quarterly report.', target: '请查收附件中的季度报告。' },
            { category: '商务', source: 'The meeting has been rescheduled to next week.', target: '会议已重新安排到下周。' },
            { category: '科技', source: 'Artificial intelligence is transforming industries.', target: '人工智能正在改变各个行业。' },
            { category: '科技', source: 'Cloud computing provides scalable solutions.', target: '云计算提供可扩展的解决方案。' },
            { category: '科技', source: 'Machine learning algorithms improve over time.', target: '机器学习算法会随着时间不断改进。' },
            { category: '旅游', source: 'The hotel offers complimentary breakfast.', target: '酒店提供免费早餐。' },
            { category: '旅游', source: 'Please book a flight to Tokyo next month.', target: '请预订下个月去东京的航班。' },
            { category: '旅游', source: 'Tourist attractions are crowded during peak season.', target: '旅游景点在旺季非常拥挤。' },
            { category: '文化', source: 'Chinese New Year is celebrated worldwide.', target: '春节在全球范围内庆祝。' },
            { category: '文化', source: 'Traditional tea ceremony is a form of art.', target: '传统茶道是一种艺术形式。' },
            { category: '文化', source: 'Calligraphy is highly valued in East Asia.', target: '书法在东亚备受推崇。' },
            { category: '教育', source: 'Education is the key to success.', target: '教育是成功的关键。' },
            { category: '教育', source: 'Online learning has become increasingly popular.', target: '在线学习变得越来越流行。' },
            { category: '教育', source: 'Scholarships are available for international students.', target: '国际学生可申请奖学金。' },
            { category: '医疗', source: 'Regular exercise promotes good health.', target: '规律运动促进健康。' },
            { category: '医疗', source: 'The patient is in stable condition.', target: '患者情况稳定。' },
            { category: '医疗', source: 'Vaccination is essential for public health.', target: '疫苗接种对公共卫生至关重要。' },
            { category: '法律', source: 'The contract will be signed tomorrow.', target: '合同将于明天签署。' },
            { category: '法律', source: 'Intellectual property rights must be protected.', target: '知识产权必须受到保护。' },
            { category: '金融', source: 'Stock market volatility affects investors.', target: '股市波动影响投资者。' },
            { category: '金融', source: 'Interest rates have been lowered by the central bank.', target: '央行降低了利率。' },
            { category: '金融', source: 'Foreign exchange rates fluctuate daily.', target: '外汇汇率每天波动。' },
            { category: '环保', source: 'Renewable energy reduces carbon emissions.', target: '可再生能源减少碳排放。' },
            { category: '环保', source: 'Plastic pollution is a global problem.', target: '塑料污染是一个全球性问题。' }
        ];

        let db;
        let recognition;
        let isRecording = false;

        function initDB() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open(DB_NAME, DB_VERSION);
                
                request.onupgradeneeded = (event) => {
                    db = event.target.result;
                    if (!db.objectStoreNames.contains(STORE_NAME)) {
                        const store = db.createObjectStore(STORE_NAME, { keyPath: 'id', autoIncrement: true });
                        store.createIndex('source', 'source', { unique: false });
                        store.createIndex('timestamp', 'timestamp', { unique: false });
                    }
                };
                
                request.onsuccess = (event) => {
                    db = event.target.result;
                    resolve(db);
                };
                
                request.onerror = (event) => {
                    reject(event.target.error);
                };
            });
        }

        async function addTranslation(source, target, sourceLang, targetLang) {
            return new Promise((resolve, reject) => {
                const transaction = db.transaction([STORE_NAME], 'readwrite');
                const store = transaction.objectStore(STORE_NAME);
                const request = store.add({
                    source,
                    target,
                    sourceLang,
                    targetLang,
                    timestamp: Date.now()
                });
                
                request.onsuccess = () => resolve(request.result);
                request.onerror = () => reject(request.error);
            });
        }

        async function getAllTranslations() {
            return new Promise((resolve, reject) => {
                const transaction = db.transaction([STORE_NAME], 'readonly');
                const store = transaction.objectStore(STORE_NAME);
                const request = store.getAll();
                
                request.onsuccess = () => resolve(request.result.reverse());
                request.onerror = () => reject(request.error);
            });
        }

        async function deleteTranslation(id) {
            return new Promise((resolve, reject) => {
                const transaction = db.transaction([STORE_NAME], 'readwrite');
                const store = transaction.objectStore(STORE_NAME);
                const request = store.delete(id);
                
                request.onsuccess = () => resolve();
                request.onerror = () => reject(request.error);
            });
        }

        async function searchInMemory(query) {
            const translations = await getAllTranslations();
            return translations.filter(t => 
                t.source.toLowerCase().includes(query.toLowerCase()) ||
                t.target.toLowerCase().includes(query.toLowerCase())
            );
        }

        function formatDate(timestamp) {
            const date = new Date(timestamp);
            return date.toLocaleString('zh-CN', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function getLangName(code) {
            const langs = {
                en: '英语',
                zh: '中文',
                ja: '日语',
                ko: '韩语',
                fr: '法语',
                de: '德语',
                es: '西班牙语',
                ru: '俄语'
            };
            return langs[code] || code;
        }

        async function translateText() {
            const inputText = document.getElementById('inputText').value.trim();
            const sourceLang = document.getElementById('sourceLang').value;
            const targetLang = document.getElementById('targetLang').value;
            const btn = document.getElementById('translateBtn');
            const btnText = document.getElementById('btnText');
            const outputText = document.getElementById('outputText');

            if (!inputText) {
                alert('请输入要翻译的文本');
                return;
            }

            btn.disabled = true;
            btnText.innerHTML = '<span class="loading-spinner"></span>翻译中...';

            try {
                const translations = await getAllTranslations();
                const existing = translations.find(t => 
                    t.source === inputText && t.sourceLang === sourceLang && t.targetLang === targetLang
                );

                if (existing) {
                    outputText.value = existing.target;
                    const matches = parseInt(document.getElementById('memoryMatches').textContent) + 1;
                    document.getElementById('memoryMatches').textContent = matches;
                    document.getElementById('savedTime').textContent = matches * 3;
                } else {
                    const result = await fetchTranslation(inputText, sourceLang, targetLang);
                    outputText.value = result;
                    await addTranslation(inputText, result, sourceLang, targetLang);
                    updateMemoryStats();
                }

                loadMemoryList();
            } catch (error) {
                console.error('Translation error:', error);
                outputText.value = '翻译失败，请稍后重试。错误信息：' + error.message;
            } finally {
                btn.disabled = false;
                btnText.textContent = '开始翻译';
            }
        }

        async function fetchTranslation(text, source, target) {
            const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${source}&tl=${target}&dt=t&q=${encodeURIComponent(text)}`;
            
            const response = await fetch(url);
            if (!response.ok) {
                throw new Error('HTTP ' + response.status);
            }
            
            const data = await response.json();
            return data[0][0][0];
        }

        function swapLanguages() {
            const sourceSelect = document.getElementById('sourceLang');
            const targetSelect = document.getElementById('targetLang');
            const inputText = document.getElementById('inputText');
            const outputText = document.getElementById('outputText');

            const tempLang = sourceSelect.value;
            sourceSelect.value = targetSelect.value;
            targetSelect.value = tempLang;

            const tempText = inputText.value;
            inputText.value = outputText.value;
            outputText.value = tempText;
        }

        async function loadMemoryList() {
            const translations = await getAllTranslations();
            const list = document.getElementById('memoryList');
            
            if (translations.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <i>📭</i>
                        <p>暂无翻译记录</p>
                        <p style="font-size: 0.9rem; margin-top: 10px;">在"文本翻译"页面进行翻译后，记录会自动保存到这里</p>
                    </div>
                `;
                return;
            }

            list.innerHTML = translations.map(t => `
                <div class="memory-item">
                    <div class="memory-text">
                        <div class="memory-source">
                            <span>${getLangName(t.sourceLang)}</span>
                            <p>${t.source}</p>
                        </div>
                        <div class="memory-target">
                            <span>${getLangName(t.targetLang)}</span>
                            <p>${t.target}</p>
                        </div>
                    </div>
                    <div class="memory-time">${formatDate(t.timestamp)}</div>
                    <div class="memory-actions">
                        <button class="action-btn copy" onclick="copyToClipboard('${t.target.replace(/'/g, "\\'")}')">复制</button>
                        <button class="action-btn restore" onclick="restoreTranslation('${t.source.replace(/'/g, "\\'")}', '${t.target.replace(/'/g, "\\'")}', '${t.sourceLang}', '${t.targetLang}')">恢复</button>
                        <button class="action-btn delete" onclick="deleteAndRefresh(${t.id})">删除</button>
                    </div>
                </div>
            `).join('');
        }

        async function searchMemory() {
            const query = document.getElementById('memorySearch').value;
            const translations = await searchInMemory(query);
            const list = document.getElementById('memoryList');

            if (translations.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <i>🔍</i>
                        <p>未找到匹配的记录</p>
                    </div>
                `;
                return;
            }

            list.innerHTML = translations.map(t => `
                <div class="memory-item">
                    <div class="memory-text">
                        <div class="memory-source">
                            <span>${getLangName(t.sourceLang)}</span>
                            <p>${t.source}</p>
                        </div>
                        <div class="memory-target">
                            <span>${getLangName(t.targetLang)}</span>
                            <p>${t.target}</p>
                        </div>
                    </div>
                    <div class="memory-time">${formatDate(t.timestamp)}</div>
                    <div class="memory-actions">
                        <button class="action-btn copy" onclick="copyToClipboard('${t.target.replace(/'/g, "\\'")}')">复制</button>
                        <button class="action-btn restore" onclick="restoreTranslation('${t.source.replace(/'/g, "\\'")}', '${t.target.replace(/'/g, "\\'")}', '${t.sourceLang}', '${t.targetLang}')">恢复</button>
                        <button class="action-btn delete" onclick="deleteAndRefresh(${t.id})">删除</button>
                    </div>
                </div>
            `).join('');
        }

        async function deleteAndRefresh(id) {
            if (confirm('确定要删除这条记录吗？')) {
                await deleteTranslation(id);
                loadMemoryList();
                updateMemoryStats();
            }
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                alert('已复制到剪贴板');
            });
        }

        function restoreTranslation(source, target, sourceLang, targetLang) {
            document.getElementById('inputText').value = source;
            document.getElementById('outputText').value = target;
            document.getElementById('sourceLang').value = sourceLang;
            document.getElementById('targetLang').value = targetLang;
            switchTab('translate');
        }

        async function updateMemoryStats() {
            const translations = await getAllTranslations();
            document.getElementById('totalTranslations').textContent = translations.length;
        }

        function loadCorpus() {
            const grid = document.getElementById('corpusGrid');
            grid.innerHTML = corpusData.map((item, index) => `
                <div class="corpus-card" onclick="showCorpusDetail(${index})">
                    <h3>${item.source}</h3>
                    <p>${item.target}</p>
                    <span class="corpus-category">${item.category}</span>
                </div>
            `).join('');
        }

        function searchCorpus() {
            const query = document.getElementById('corpusSearch').value.toLowerCase();
            const grid = document.getElementById('corpusGrid');
            
            const filtered = corpusData.filter(item => 
                item.source.toLowerCase().includes(query) ||
                item.target.toLowerCase().includes(query) ||
                item.category.includes(query)
            );

            if (filtered.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state" style="grid-column: 1 / -1;">
                        <i>📚</i>
                        <p>未找到匹配的语料</p>
                    </div>
                `;
                return;
            }

            grid.innerHTML = filtered.map((item, index) => `
                <div class="corpus-card" onclick="showCorpusDetail(${corpusData.indexOf(item)})">
                    <h3>${item.source}</h3>
                    <p>${item.target}</p>
                    <span class="corpus-category">${item.category}</span>
                </div>
            `).join('');
        }

        function showCorpusDetail(index) {
            const item = corpusData[index];
            document.getElementById('inputText').value = item.source;
            document.getElementById('outputText').value = item.target;
            document.getElementById('sourceLang').value = 'en';
            document.getElementById('targetLang').value = 'zh';
            switchTab('translate');
        }

        function toggleSubtitle() {
            const micBtn = document.getElementById('micBtn');
            const status = document.getElementById('subtitleStatus');

            if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
                alert('您的浏览器不支持语音识别功能，请使用Chrome或Edge浏览器');
                return;
            }

            if (isRecording) {
                stopSubtitle();
            } else {
                startSubtitle();
            }
        }

        function startSubtitle() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            recognition = new SpeechRecognition();
            
            const sourceLang = document.getElementById('subtitleSourceLang').value;
            recognition.lang = sourceLang === 'zh' ? 'zh-CN' : 'en-US';
            recognition.continuous = true;
            recognition.interimResults = true;

            recognition.onresult = async (event) => {
                let transcript = '';
                for (let i = event.resultIndex; i < event.results.length; i++) {
                    transcript += event.results[i][0].transcript;
                }
                
                document.getElementById('subtitleOriginal').textContent = transcript;
                
                if (event.results[event.results.length - 1].isFinal && transcript.trim()) {
                    try {
                        const targetLang = document.getElementById('subtitleTargetLang').value;
                        const translation = await fetchTranslation(transcript, sourceLang, targetLang);
                        document.getElementById('subtitleTranslated').textContent = translation;
                    } catch (error) {
                        console.error('Subtitle translation error:', error);
                    }
                }
            };

            recognition.onerror = (event) => {
                console.error('Speech recognition error:', event.error);
                document.getElementById('subtitleStatus').textContent = '识别出错: ' + event.error;
                stopSubtitle();
            };

            recognition.start();
            isRecording = true;
            document.getElementById('micBtn').classList.add('active');
            document.getElementById('subtitleStatus').textContent = '正在录音...';
        }

        function stopSubtitle() {
            if (recognition) {
                recognition.stop();
                recognition = null;
            }
            isRecording = false;
            document.getElementById('micBtn').classList.remove('active');
            document.getElementById('subtitleStatus').textContent = '已停止';
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(tabId).classList.add('active');

            if (tabId === 'memory') {
                loadMemoryList();
            }
        }

        document.addEventListener('DOMContentLoaded', async () => {
            await initDB();
            loadCorpus();
            updateMemoryStats();
        });
    </script>
</body>
</html>
